{
  "name": "freetyping",
  "private": true,
  "license": "MIT",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pinyin-dictionary": "node scripts/build-pinyin-dictionary.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:a11y": "npm run build && node tests/browser-audit.mjs",
    "test:browser": "npm run build && node tests/browser-smoke.mjs",
    "test:bundle": "npm run build && node tests/bundle-audit.mjs",
    "test:static": "npm run build && node tests/static-host-smoke.mjs",
    "release:check": "npm run test && npm run test:browser && npm run test:a11y && npm run test:bundle && npm run test:static"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.3",
    "vite": "^7.1.7",
    "vitest": "^4.1.7"
  }
}
